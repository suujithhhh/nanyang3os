# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
EXTERNAL_API_KEY=your_gemini_api_key_here

# Azure AI Search
# Create a free-tier search service at https://portal.azure.com
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_admin_key_here
AZURE_SEARCH_INDEX_NAME=excelearn-index

# Azure Blob Storage
# Create a storage account at https://portal.azure.com
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Firebase Service Account (optional - only needed for Firestore persistence)
# If not set, the backend uses local JSON files instead (fully functional for demo)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json